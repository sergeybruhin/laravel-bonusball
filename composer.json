{
    "name": "sergeybruhin/laravel-bonusball",
    "description": "Laravel integration for the BonusBall API",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Sergey Bruhin",
            "email": "sundaycreative@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "laravel/framework": "^13.0",
        "sergeybruhin/bonusball-client": "^0.0.1"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "BonusBall\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BonusBall\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "BonusBall\\Laravel\\BonusBallServiceProvider"
            ],
            "aliases": {
                "BonusBall": "BonusBall\\Laravel\\Facades\\BonusBall"
            }
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../bonusball-client"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}
